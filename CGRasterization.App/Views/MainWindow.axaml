<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:CGRasterization.App.ViewModels"
        xmlns:controls="clr-namespace:CGRasterization.App.Views.Controls"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="CGRasterization.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Rasterization"
        RequestedThemeVariant="Light">
        <Border
                Margin="10"
                BorderThickness="1"
                BorderBrush="#D0D7DE"
                Background="#F8F9FB"
                BoxShadow="0 4 14 0 #22000000">
                <controls:CanvasControl DataContext="{Binding CanvasControlViewModel}"/>
        </Border>
</Window>

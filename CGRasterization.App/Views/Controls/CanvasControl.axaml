<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:CGRasterization.App.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:DataType="vm:CanvasControlViewModel"
             x:Class="CGRasterization.App.Views.Controls.CanvasControl">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"></ColumnDefinition>
            <ColumnDefinition Width="3*"></ColumnDefinition>
        </Grid.ColumnDefinitions>
        
        <Border Grid.Row="0"
                Grid.ColumnSpan="2"
                Background="White"
                Padding="10"
                BorderBrush="#DADADA"
                BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal"
                        Spacing="8"
                        VerticalAlignment="Center">
                <TextBlock Text="Tools"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>
                <RadioButton Content="Select"
                             GroupName="ShapeTypes"
                             IsChecked="{Binding IsSelectShapeMode}"
                             Command="{Binding SetSelectShapeToolCommand}" />
                <RadioButton Content="Line"
                             GroupName="ShapeTypes"
                             IsChecked="{Binding IsDrawLineMode}"
                             Command="{Binding SetLineDrawToolCommand}" />
                <RadioButton Content="Circle"
                             GroupName="ShapeTypes"
                             IsChecked="{Binding IsDrawCircleMode}"
                             Command="{Binding SetCircleDrawToolCommand}" />
                <RadioButton Content="Polygon"
                             GroupName="ShapeTypes"
                             IsChecked="{Binding IsDrawPolygonMode}"
                             Command="{Binding SetPolygonDrawToolCommand}" />
            </StackPanel>
        </Border>
        
        <Border Grid.Row="1"
                Grid.Column="0"
                Background="White"
                Padding="14"
                BorderBrush="#DADADA"
                BorderThickness="0,0,1,0">

            <StackPanel Spacing="16">
                <TextBlock Text="Inspector"
                           FontSize="18"
                           FontWeight="Bold"/>
                <StackPanel Spacing="6">
                    <TextBlock Text="Selected shape"
                               FontWeight="SemiBold"/>
                        <StackPanel Orientation="Vertical" Spacing="6" 
                                    Opacity="{Binding SelectedShapeControlsOpacity}">
                            <TextBlock Text="{Binding SelectedShape}"
                                       TextWrapping="Wrap"/>
                            <StackPanel Spacing="4">
                                <TextBlock Text="Thickness"/>
                                <NumericUpDown Minimum="1"
                                               Maximum="15"
                                               Increment="2"
                                               Value="{Binding SelectedShapeThickness}" />
                            </StackPanel>
                            <StackPanel Spacing="4"
                                        Orientation="Vertical"
                                        HorizontalAlignment="Left">
                                <TextBlock Text="Color"/>
                                <ColorPicker Color="{Binding SelectedShapeBrushColorPicker, Mode=TwoWay}"
                                             VerticalAlignment="Top"/>
                            </StackPanel>
                        </StackPanel>
                </StackPanel>

                <StackPanel Spacing="8"
                            Opacity="{Binding SelectedShapeControlsOpacity}">
                    <TextBlock Text="Actions"
                               FontWeight="SemiBold"/>
                    <ToggleButton Content="Move selected shape"
                                  IsChecked="{Binding IsMoveShapeMode}"
                                  Command="{Binding MoveShapeCommand}"/>
                    <ToggleButton Content="Edit selected shape"
                                  IsChecked="{Binding IsEditShapeMode}"
                                  Command="{Binding EditShapeCommand}"/>
                    <Button Content="Remove selected shape"
                            Command="{Binding RemoveShapeCommand}" />
                </StackPanel>
                <Separator Margin="0,4,0,0"/>

               
                <StackPanel Spacing="10">
                    <TextBlock Text="Brush"
                               FontWeight="SemiBold"/>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Thickness"/>

                        <NumericUpDown Minimum="1"
                                       Maximum="15"
                                       Increment="2"
                                       Value="{Binding Canvas.BrushThickness}" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Color"/>
                        <StackPanel Orientation="Horizontal"
                                    Spacing="8"
                                    VerticalAlignment="Center">
                            <ColorPicker Color="{Binding Canvas.BrushColorPicker, Mode=TwoWay}" />
                            <TextBlock Text="{Binding Canvas.BrushColorName}"
                                       TextAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>
        
        <ScrollViewer Grid.Row="1" 
                      Grid.Column="1"
                      HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
            <Image x:Name="CanvasImage"
                   Source="{Binding Canvas.ImageSource}"
                   Stretch="None"
                   PointerPressed="InputElement_OnPointerPressed"
                   PointerMoved="InputElement_OnPointerMoved"
                   PointerReleased="InputElement_OnPointerReleased"/>
        </ScrollViewer>
    </Grid>
</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:CGRasterization.App.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:DataType="vm:CanvasControlViewModel"
             x:Class="CGRasterization.App.Views.Controls.CanvasControl">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"></ColumnDefinition>
            <ColumnDefinition Width="3*"></ColumnDefinition>
        </Grid.ColumnDefinitions>
        
        <Border Grid.Row="0"
                Grid.ColumnSpan="2"
                Background="White"
                Padding="10"
                BorderBrush="#DADADA"
                BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal"
                        Spacing="8"
                        VerticalAlignment="Center">
                <TextBlock Text="Tools"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>
                <RadioButton Content="Select"
                             GroupName="ShapeTypes"
                             IsChecked="{Binding IsSelectShapeMode}"
                             Command="{Binding SetSelectShapeToolCommand}" />
                <RadioButton Content="Line"
                             GroupName="ShapeTypes"
                             IsChecked="{Binding IsDrawLineMode}"
                             Command="{Binding SetLineDrawToolCommand}" />
                <RadioButton Content="Circle"
                             GroupName="ShapeTypes"
                             IsChecked="{Binding IsDrawCircleMode}"
                             Command="{Binding SetCircleDrawToolCommand}" />
            </StackPanel>
        </Border>
        
        <Border Grid.Row="1"
                Grid.Column="0"
                Background="White"
                Padding="14"
                BorderBrush="#DADADA"
                BorderThickness="0,0,1,0">

            <StackPanel Spacing="16">
                <TextBlock Text="Inspector"
                           FontSize="18"
                           FontWeight="Bold"/>
                <StackPanel Spacing="6">
                    <TextBlock Text="Selected shape"
                               FontWeight="SemiBold"/>
                    <Border Background="#F7F7F7"
                            BorderBrush="#E0E0E0"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="8"
                            MinHeight="70">
                        <TextBlock Text="{Binding SelectedShape}"
                                   TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>

                <StackPanel Spacing="8"
                            Opacity="{Binding SelectedShapeControlsOpacity}">
                    <TextBlock Text="Actions"
                               FontWeight="SemiBold"/>
                    <ToggleButton Content="Move selected shape"
                                  IsChecked="{Binding IsMoveShapeMode}"
                                  Command="{Binding MoveShapeCommand}"/>
                    <Button Content="Remove selected shape"
                            Command="{Binding RemoveShapeCommand}" />
                </StackPanel>
            </StackPanel>
        </Border>
        
        <ScrollViewer Grid.Row="1" 
                      Grid.Column="1"
                      HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
            <Image x:Name="CanvasImage"
                   Source="{Binding Canvas.ImageSource}"
                   Stretch="None"
                   PointerPressed="InputElement_OnPointerPressed"
                   PointerMoved="InputElement_OnPointerMoved"
                   PointerReleased="InputElement_OnPointerReleased"/>
        </ScrollViewer>
    </Grid>
</UserControl>
